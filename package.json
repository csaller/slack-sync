{
  "name": "slack-sync",
  "version": "1.1.2",
  "description": "Sync Google Calendar events to Slack status",
  "main": "dist/index.js",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "start": "node dist/index.js",
    "setup": "pnpm run build && node dist/index.js --setup",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "googleapis": "^171.4.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
