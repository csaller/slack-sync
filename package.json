{
  "name": "slack-sync",
  "version": "1.0.0",
  "description": "Sync Google Calendar events to Slack status",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "setup": "bun run src/index.ts --setup",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "googleapis": "^144.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
